# ═══════════════════════════════════════════════════════════════
#  JobApplyPro v2 — Environment Variables
#  Copy this file to .env and fill in every value below.
#  Never commit .env to git (it is already in .gitignore).
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Database (REQUIRED) ──────────────────────────────────────────
# Local dev:  postgresql://jap:yourpassword@localhost:5432/jobapplypro
# Docker:     postgresql://jap:yourpassword@postgres:5432/jobapplypro
DATABASE_URL=postgresql://jap:CHANGE_ME@postgres:5432/jobapplypro
POSTGRES_DB=jobapplypro
POSTGRES_USER=jap
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── Session Secret (REQUIRED) ────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_AT_LEAST_32_CHARS

# ── Google OAuth + Gmail (REQUIRED) ──────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web Application)
# 3. Enable "Gmail API" in the API Library
# 4. Add Authorized redirect URI:
#    - Dev:  http://localhost:3000/auth/google/callback
#    - Prod: https://yourdomain.com/auth/google/callback
# 5. Scopes required: openid, profile, email, gmail.readonly
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Encryption Key (REQUIRED) ────────────────────────────────────
# AES-256-GCM key — MUST be exactly 64 hex characters (= 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_EXACTLY

# ── Frontend URL ─────────────────────────────────────────────────
# Dev:  http://localhost:5173
# Prod: https://yourdomain.com
CLIENT_URL=http://localhost:5173

# ── Optional: LinkedIn Cookie ────────────────────────────────────
# Improves LinkedIn scrape quality and rate limits.
# How to get it:
#   1. Log in to linkedin.com in Chrome
#   2. Open DevTools → Application → Cookies → www.linkedin.com
#   3. Copy the value of the "li_at" cookie
# Leave blank to use public guest API (still works, fewer results).
LINKEDIN_COOKIE=

# ── Optional: Naukri Session Cookie ─────────────────────────────
# Improves Naukri API results.
# How to get it:
#   1. Log in to naukri.com in Chrome
#   2. Open DevTools → Network → any request → Request Headers → Cookie
#   3. Copy the entire Cookie header value
# Leave blank to use public API.
NAUKRI_COOKIE=

# ── Docker host port ─────────────────────────────────────────────
HOST_PORT=80
